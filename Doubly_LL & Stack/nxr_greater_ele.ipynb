     "text": [
      "4 -> 5\n",
      "5 -> 25\n",
      "2 -> 25\n",
      "25 -> -1\n"
     ]
    }
   ],
   "source": [
    "arr = [4, 5, 2, 25]\n",
    "\n",
    "for i in range(len(arr)):\n",
    "    next_greater = -1\n",
    "\n",
    "    for j in range(i + 1, len(arr)):\n",
    "        if arr[j] > arr[i]:\n",
    "            next_greater = arr[j]\n",
    "            break\n",
    "\n",
    "    print(arr[i], \"->\", next_greater)"
   ]
  }
 ],
