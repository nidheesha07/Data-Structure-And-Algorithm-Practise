   "id": "09dd1a96",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "15\n"
     ]
    }
   ],
   "source": [
    "nums = [4, 8, 2, 15, 7]\n",
    "max = nums[0]\n",
    "for num in nums:\n",
    "    if num > max:\n",
    "        max = num\n",
    "print(max)"
   ]
